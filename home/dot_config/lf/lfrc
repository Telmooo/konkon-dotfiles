# Options
set shell fish
set shellopts '-c'
set ifs "\n"
set scrolloff 5
set icons true
set period 1
set hidden true
set info size
set sortby natural
set ignorecase true
set preview true
set cleaner '~/.config/lf/cleaner'
set previewer '~/.config/lf/previewer'

# Commands
cmd open ${{
    case $(file --mime-type "$f" -bL) in
        text/*|application/json|application/x-ndjson|inode/x-empty) $EDITOR "$f" ;;
        image/*) imv "$f" ;;
        video/*|audio/*) mpv "$f" ;;
        application/pdf) zathura "$f" ;;
        *) xdg-open "$f" ;;
    esac
}}

cmd mkdir ${{
    printf "Directory name: "
    read ans
    mkdir -p "$ans"
}}

cmd mkfile ${{
    printf "File name: "
    read ans
    touch "$ans"
}}

cmd delete ${{
    set -l files (echo "$fx" | tr "\n" " ")
    printf "Delete $files? [y/N] "
    read ans
    if test "$ans" = "y"
        rm -rf $files
    end
}}

cmd trash ${{
    set -l files (echo "$fx" | tr "\n" " ")
    trash $files
}}

cmd extract ${{
    case "$f" in
        *.tar.bz2) tar xjf "$f" ;;
        *.tar.gz)  tar xzf "$f" ;;
        *.tar.xz)  tar xJf "$f" ;;
        *.tar.zst) tar --use-compress-program=unzstd -xf "$f" ;;
        *.tar)     tar xf "$f" ;;
        *.zip)     unzip "$f" ;;
        *.7z)      7z x "$f" ;;
        *.rar)     unrar x "$f" ;;
        *) echo "Unsupported archive: $f" ;;
    esac
}}

cmd fzf_jump ${{
    res="$(find . -maxdepth 3 | fzf --reverse --header='Jump to location')"
    if [ -n "$res" ]; then
        if [ -d "$res" ]; then
            cmd="cd"
        else
            cmd="select"
        fi
        lf -remote "send $id $cmd \"$res\""
    fi
}}

cmd on-cd &{{
    # Show current directory in window title
    printf "\033]0; lf - $(pwd | sed "s|$HOME|~|")\007" > /dev/tty
}}

on-cd

# Key bindings
# Navigation
map h updir
map l open
map <enter> open
map . set hidden!
map <esc> clear

# File operations
map e $EDITOR "$f"
map o &xdg-open "$f"
map D delete
map T trash
map x extract

# Create
map md mkdir
map mf mkfile

# Jump
map J fzf_jump

# Selection
map <space> toggle
map V invert
map U unselect

# Copy/paste
map y copy
map d cut
map p paste
map P :{{ paste; clear }}

# Rename
map r push :rename<space>
map R :bulk-rename

# Reload
map <c-r> reload
map <c-l> redraw
